# ─────────────────────────────────────────────────────────────────────
# vc-age-verification — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────

# ── Ethereum / Network ───────────────────────────────────────────────
CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545

# For Sepolia testnet:
# CHAIN_ID=11155111
# RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# For local L1 (docker compose):
# CHAIN_ID=900
# RPC_URL=http://127.0.0.1:9545
# BLOCKCHAIN_LOCAL_RPC_URL=http://127.0.0.1:9545
# DEPLOYER_PRIVATE_KEY=<private key funded in your L1 genesis>

# ── Issuer wallet (backend) ──────────────────────────────────────────
# Private key of the VC issuer's Ethereum wallet.
# Hardhat default account #0 key (safe for local dev only):
ISSUER_PRIVATE_KEY=<YOUR_ISSUER_PRIVATE_KEY>

# ── Contract addresses (populated by deploy script) ──────────────────
COMMITMENT_REGISTRY_ADDRESS=
AGE_REGISTRY_ADDRESS=

# ── Backend server ────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:5173

# ── Etherscan (for contract verification) ────────────────────────────
ETHERSCAN_API_KEY=

# ── Vite frontend env (prefix with VITE_) ────────────────────────────
VITE_BACKEND_URL=http://localhost:3001
VITE_AGE_REGISTRY_ADDRESS=
VITE_COMMITMENT_REGISTRY_ADDRESS=

# ── Rust prover ───────────────────────────────────────────────────────
# Port for the Rust Groth16 prover service
PROVER_PORT=8080
CIRCUITS_BUILD_DIR=../circuits/build
